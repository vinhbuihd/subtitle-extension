{
  "manifest_version": 3,
  "name": "Movie English Study Overlay",
  "version": "0.1.0",
  "description": "Show synced local English subtitles beside an HTML5 video.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Toggle Movie English Study"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ]
}
